# Krythor environment variables — copy to .env or set in your shell/service manager
# Values shown are examples only. Never commit real API keys to source control.

# ── Data directory ────────────────────────────────────────────────────────────
# Override where Krythor stores all data (memory DB, config, logs, backups).
# Defaults: Windows=%LOCALAPPDATA%\Krythor  macOS=~/Library/Application Support/Krythor  Linux=~/.local/share/krythor
# KRYTHOR_DATA_DIR=/data/krythor

# ── Provider API keys (referenced as ${VAR_NAME} in providers.json) ───────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here
OPENROUTER_API_KEY=sk-or-v1-your-key-here
GROQ_API_KEY=gsk_your-key-here
# VENICE_API_KEY=your-key-here

# ── Gateway network ───────────────────────────────────────────────────────────
# Extra CORS origins allowed to call the API (comma-separated).
# Default: loopback only (http://127.0.0.1:47200 and http://localhost:47200)
# CORS_ORIGINS=http://my-dev-tool.local:3000

# ── Memory system ─────────────────────────────────────────────────────────────
# Set to 1 to disable temporal decay in memory search scoring.
# KRYTHOR_MEMORY_NO_DECAY=1

# ── Install / setup ───────────────────────────────────────────────────────────
# Set to 1 to skip all interactive prompts (CI / unattended install).
# KRYTHOR_NON_INTERACTIVE=1

# ── Development / testing ─────────────────────────────────────────────────────
# NODE_ENV=test          — disables timers (config watcher, heartbeat, session cleanup)
# KRYTHOR_TEST_ANTHROPIC_KEY=sk-ant-...   — live provider tests
# KRYTHOR_TEST_OPENAI_KEY=sk-proj-...     — live provider tests
# KRYTHOR_TEST_OLLAMA_URL=http://127.0.0.1:11434
