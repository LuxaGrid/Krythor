{
  "name": "krythor",
  "version": "0.1.0",
  "private": true,
  "description": "Krythor — local-first AI command platform",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @krythor/gateway dev",
    "start": "node start.js",
    "setup": "node packages/setup/dist/bin/setup.js",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "node-gyp": "^12.2.0"
  }
}
