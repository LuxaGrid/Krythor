{
  "name": "@krythor/gateway",
  "version": "0.1.213",
  "private": true,
  "description": "Krythor Gateway — local HTTP and WebSocket service layer",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.0",
    "@krythor/core": "workspace:*",
    "@krythor/guard": "workspace:*",
    "@krythor/memory": "workspace:*",
    "@krythor/models": "workspace:*",
    "@krythor/skills": "workspace:*",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
