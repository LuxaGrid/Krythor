{
  "name": "@krythor/setup",
  "version": "0.1.0",
  "private": true,
  "description": "Krythor Setup — installer and onboarding wizard",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "krythor-setup": "dist/bin/setup.js",
    "krythor": "dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "setup": "node dist/bin/setup.js",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@krythor/core": "workspace:*",
    "@krythor/guard": "workspace:*",
    "@krythor/memory": "workspace:*",
    "@krythor/models": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
